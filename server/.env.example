# Port de l'API
PORT=5000

# Connexion MongoDB (local ou Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/elegance

# Secret JWT (mettez une longue chaîne aléatoire)
JWT_SECRET=change-me-please-very-long-random-string

# Origine autorisée pour le frontend (CORS)
CLIENT_URL=http://localhost:5173

# Chargily Pay (laisser vide pour désactiver le paiement en ligne)
CHARGILY_SECRET_KEY=
CHARGILY_MODE=test
CHARGILY_SUCCESS_URL=http://localhost:5173/order/confirmed
CHARGILY_FAILURE_URL=http://localhost:5173/cart
CHARGILY_WEBHOOK_URL=
